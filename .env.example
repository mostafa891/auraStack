# General Settings
DEBUG=True
SECRET_KEY=your-super-secret-django-key
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000

# Database Settings
# For local development (sqlite by default, no env needed)
# For Docker/Production (Postgres):
# DATABASE_URL=postgres://postgres:postgres@db:5432/auraflow

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production (Anymail/Resend):
# EMAIL_BACKEND=anymail.backends.resend.EmailBackend
# RESEND_API_KEY=re_your_api_key
# For production (SMTP):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=your_smtp_password
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=onboarding@yourdomain.com

# Sentry Settings
SENTRY_DSN=

# Storage Settings (S3/Cloudflare R2)
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL= # Required for Cloudflare R2 / MinIO

# Payment Gateways (Stripe keys)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

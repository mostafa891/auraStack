# ==============================================================================
# AuraFlow — Environment Variables Reference
# Copy this file to .env and fill in your values
# ==============================================================================

# ==============================================================================
# General Settings
# ==============================================================================
DEBUG=True
SECRET_KEY=your-super-secret-django-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# REQUIRED in production: Your app's public URL (used in invite links, Stripe redirects, etc.)
SITE_URL=http://localhost:8000

# ==============================================================================
# Database Settings
# ==============================================================================
# Local development uses SQLite by default (no config needed)
# For Docker / Production (PostgreSQL):
# DATABASE_URL=postgres://postgres:postgres@db:5432/auraflow

# ==============================================================================
# Redis (REQUIRED in production for Rate Limiting + Background Tasks)
# ==============================================================================
# Without Redis, rate limiting will NOT work correctly across multiple containers
# Local: leave blank to use ORM broker (slower but works)
# Production: set this to your Redis URL
REDIS_URL=

# ==============================================================================
# Email Settings
# ==============================================================================
# Development: prints emails to console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production option 1 — Anymail/Resend (recommended):
# EMAIL_BACKEND=anymail.backends.resend.EmailBackend
# RESEND_API_KEY=re_your_api_key

# Production option 2 — SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=your_smtp_password
# EMAIL_USE_TLS=True

DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ==============================================================================
# Monitoring (Sentry)
# ==============================================================================
SENTRY_DSN=

# ==============================================================================
# Storage — S3 / Cloudflare R2
# ==============================================================================
USE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
# Required for Cloudflare R2 or MinIO:
AWS_S3_ENDPOINT_URL=

# ==============================================================================
# Payment Gateways
# ==============================================================================

# --- Stripe (fully implemented) ---
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Paymob (fully implemented — Egyptian & MENA market) ---
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# --- LemonSqueezy (fully implemented) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Paddle (implemented) ---
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox

# --- PayPal (implemented) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=sandbox

# ==============================================================================
# Social Auth (Google + GitHub)
# ==============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

